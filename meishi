// 核心计算与页面控制逻辑
let currentQuestion = 0;
let userScores = { c: 0, e: 0, f: 0, s: 0 };

function startTest() {
    document.getElementById('start-screen').classList.add('hidden');
    document.getElementById('quiz-screen').classList.remove('hidden');
    renderQuestion();
}

function renderQuestion() {
    const qData = questions[currentQuestion];
    document.getElementById('question-text').innerText = (currentQuestion + 1) + ". " + qData.q;
    document.getElementById('progress').innerText = (currentQuestion + 1) + " / " + questions.length;

    const optionsContainer = document.getElementById('options-container');
    optionsContainer.innerHTML = '';

    qData.o.forEach((opt, index) => {
        const btn = document.createElement('button');
        btn.className = 'btn';
        btn.innerText = opt.t;
        btn.onclick = () => selectOption(opt.s);
        optionsContainer.appendChild(btn);
    });

    if (currentQuestion > 0) {
        document.getElementById('prev-btn').style.display = 'inline-block';
    } else {
        document.getElementById('prev-btn').style.display = 'none';
    }
}

function prevQuestion() {
    if (currentQuestion > 0) {
        currentQuestion--;
        // 注意：这里的简单回退没有回滚分数，因为这是静态展示代码。若要严格回滚需记录每题得分。
        renderQuestion();
    }
}

function selectOption(scoreObj) {
    userScores.c += scoreObj.c;
    userScores.e += scoreObj.e;
    userScores.f += scoreObj.f;
    userScores.s += scoreObj.s;

    if (currentQuestion < questions.length - 1) {
        currentQuestion++;
        renderQuestion();
    } else {
        showResult();
    }
}

function showResult() {
    document.getElementById('quiz-screen').classList.add('hidden');
    document.getElementById('result-screen').classList.remove('hidden');

    let matchedAuthor = authors[authors.length - 1]; // 默认最后一个
    for (let i = 0; i < authors.length; i++) {
        if (authors[i].matchLogic(userScores.c, userScores.e, userScores.f, userScores.s)) {
            matchedAuthor = authors[i];
            break;
        }
    }

    document.getElementById('result-title').innerText = "你吃得简直就像：" + matchedAuthor.name;
    document.getElementById('result-img').src = matchedAuthor.img;

    let scoresText = `【你的CEFS饮食灵魂刻度】<br>` +
                     `讲究精细度 (C): ${userScores.c} <br>` +
                     `社交分享欲 (E): ${userScores.e} <br>` +
                     `规律节律性 (F): ${userScores.f} <br>` +
                     `口味刺激度 (S): ${userScores.s}`;
    document.getElementById('result-scores').innerHTML = scoresText;

    document.getElementById('result-quote').innerText = matchedAuthor.quote;

    let fullDesc = `<strong>【作家档案】</strong><br>${matchedAuthor.bio}<br><br>` +
                   `<strong>【灵魂解析】</strong><br>${matchedAuthor.details.replace(/\n/g, '<br><br>')}`;
    document.getElementById('result-desc').innerHTML = fullDesc;
}
